PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Cambia JWT_SECRET en produccion por un valor largo y aleatorio
JWT_SECRET=sissep_dev_secret_cambia_en_produccion
JWT_EXPIRES_IN=8h

# Credenciales de PostgreSQL (deben coincidir con docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=sissep_user
DB_PASS=sissep_pass
DB_NAME=sissep_db

# Directorio base donde se guardan los archivos subidos
UPLOAD_BASE=uploads
MAX_FILE_MB=20
